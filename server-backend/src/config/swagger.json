    "/api/certificates/bulk/issue": {
      "post": {
        "tags": [
          "Certificates"
        ],
        "summary": "Finalize and execute bulk issuance (requires uniUser role)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sessionId": {
                    "type": "string"
                  },
                  "confirmedRows": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  }
                },
                "required": [
                  "sessionId",
                  "confirmedRows"
                ]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Bulk issuance started, returns job ID"
          },
          "400": {
            "description": "Missing parameters or no valid rows"
          },
          "404": {
            "description": "Session expired or not found"
          },
          "500": {
            "description": "Failed to start bulk issuance"
          }
        }
      }
    },
