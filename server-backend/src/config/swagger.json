          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "System statistics"
          },
          "500": {
            "description": "Failed to fetch system stats"
          }
        }
      }
    },
    "/api/certificates/{certificateId}/revoke": {
      "patch": {
        "tags": [
          "Certificates"
        ],
        "summary": "Revoke a specific certificate (requires uniUser role)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "certificateId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": {
                    "type": "string"
                  }
                },
                "required": [
                  "reason"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Certificate revoked successfully"
          },
          "400": {
            "description": "Revocation reason is required or already revoked"
          },
          "403": {
            "description": "Access denied"
          },
          "404": {
            "description": "Certificate not found"
          },
          "500": {
            "description": "Failed to revoke certificate"
          }
        }
      }
    },
    "/api/certificates/{certificateId}": {
      "get": {
        "tags": [
          "Certificates"
        ],
        "summary": "Get details of a specific certificate by ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "certificateId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Certificate details"
          },
          "403": {
            "description": "Access denied"
          },
          "404": {
            "description": "Certificate not found"
          },
          "500": {
            "description": "Failed to fetch certificate"
          }
        }
      }
    },
    "/api/certificates/{certificateId}/download": {
      "get": {
        "tags": [
          "Certificates"
        ],
        "summary": "Download the PDF of a specific certificate",
