          },
          "500": {
            "description": "Failed to process download request"
          }
        }
      }
    },
    "/api/certificates/{certificateId}/share": {
      "post": {
        "tags": [
          "Certificates"
        ],
        "summary": "Generate a public share link for a certificate (requires Student role)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "certificateId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Share link generated"
